<div class="p-5 rounded-sm border border-woodsmoke-800 bg-woodsmoke-925">
  <div class="w-full aspect-square rounded-sm bg-woodsmoke-925 flex items-center justify-center overflow-hidden mb-4">
    <svg class="w-24 h-24 text-woodsmoke-700" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
      <rect x="3" y="3" width="18" height="18" rx="2" />
      <path d="M3 9h18M9 21V9" />
    </svg>
  </div>

  <h1 class="text-2xl font-bold text-woodsmoke-50"><%= @label.name %></h1>

  <% if @parent_label.present? %>
    <p class="text-sm text-woodsmoke-400 mt-1">
      Sublabel of
      <%= link_to @parent_label.name, label_path(@parent_label),
          class: "text-crusta-400 hover:text-crusta-300 transition-colors" %>
    </p>
  <% end %>

  <% if @label.profile.present? %>
    <p class="mt-3 text-sm text-woodsmoke-300 leading-relaxed whitespace-pre-line"><%= @label.profile %></p>
  <% end %>

  <% if @release_count > 0 %>
    <span class="inline-block mt-3 px-2 py-1 text-xs font-medium rounded bg-woodsmoke-800 text-woodsmoke-300">
      <%= @release_count %> <%= "release".pluralize(@release_count) %>
    </span>
  <% end %>

  <% if @sub_labels.any? %>
    <div class="mt-4">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-woodsmoke-400 mb-2">Sub-labels</h3>
      <div class="flex flex-wrap gap-2">
        <% @sub_labels.each do |sub| %>
          <%= link_to sub.name, label_path(sub),
              class: "px-2 py-1 text-xs rounded-sm bg-woodsmoke-800 text-woodsmoke-300
                      hover:bg-woodsmoke-700 hover:text-crusta-400 transition-colors" %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
