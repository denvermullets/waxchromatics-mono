<% if notice = flash[:notice] %>
  <p
    class="
      py-2 px-3 bg-bright-turquoise-950 mb-5 text-bright-turquoise-300
      font-medium rounded-sm inline-block
    "
    id="notice"
  >
    <%= notice %>
  </p>
<% end %>

<% prefixes = [
  { prefix: "artist:", label: "Artist" },
  { prefix: "album:", label: "Album" },
  { prefix: "label:", label: "Label" },
  { prefix: "credit:", label: "Credit" },
  { prefix: "cat#:", label: "Catalog #" },
  { prefix: "barcode:", label: "Barcode" },
] %>

<%# Controller wraps search form + turbo frame so chips inside frame can call insertPrefix %>
<div data-controller="search-prefix" class="px-32 lg:px-64">
  <h1 class="text-3xl font-bold text-woodsmoke-50">
    Welcome back,
    <span class="text-crusta-400"><%= Current.user.username %></span>
  </h1>

  <p class="mt-2 text-woodsmoke-400">What would you like to do?</p>

  <div class="mt-8 search-focus-container">
    <p class="text-xs font-semibold uppercase tracking-wider text-woodsmoke-400 mb-3">
      Search
    </p>

    <%= form_with url: search_path, method: :get, data: { turbo_frame: "search-results" } do |f| %>
      <div
        class="
          flex search-bar-border rounded-sm border border-woodsmoke-700
          bg-woodsmoke-925
        "
        data-search-prefix-target="searchBar"
      >
        <span
          class="
            search-badge flex items-center gap-1.5 pl-3 pr-3 text-xs
            font-semibold text-woodsmoke-200 border-r border-woodsmoke-700
            shrink-0
          "
          data-search-prefix-target="badge"
        >
          <span class="badge-dot">&#9679;</span>
          <span data-search-prefix-target="badgeText"></span>
        </span>

        <%= f.text_field :query,
          autocomplete: "off",
          placeholder: "Search artists, or use prefix (e.g. label: interscope)",
          class: "flex-1 min-w-0 bg-transparent px-4 py-3 text-woodsmoke-50 placeholder-woodsmoke-500 focus:outline-none",
          data: { search_prefix_target: "input", action: "input->search-prefix#detect" } %>

        <%= f.submit "Search", class: "shrink-0 px-6 py-3 bg-crusta-400 text-woodsmoke-950 font-semibold transition-all cursor-pointer rounded-r-sm", data: { search_prefix_target: "submitBtn" } %>
      </div>
    <% end %>

    <%# Hint — hidden while input is focused (CSS), updated by Stimulus %>
    <p
      class="search-hint mt-2 text-xs text-woodsmoke-500"
      data-search-prefix-target="hint"
    >
      <span class="text-woodsmoke-500">&#9679;</span> Default: searching
      <span class="text-crusta-400">artists</span> &middot; Type a prefix like
      <span class="text-crusta-400">label:</span> to switch
    </p>

    <%# Prefix panel — shown via CSS :focus-within %>
    <div
      class="
        prefix-help-panel mt-2 p-4 rounded-sm border border-woodsmoke-700
        bg-woodsmoke-925
      "
    >
      <p
        class="
          text-xs font-semibold uppercase tracking-wider text-woodsmoke-400
          mb-3
        "
      >
        Search Prefixes
      </p>

      <div class="grid grid-cols-2 gap-x-8 gap-y-3">
        <% prefixes.each do |p| %>
          <%= render "dashboard/prefix_button", prefix: p[:prefix], label: p[:label], variant: :panel %>
        <% end %>
      </div>
    </div>
  </div>

  <%= turbo_frame_tag "search-results" do %>
    <div class="mt-16 text-center">
      <p class="text-sm text-woodsmoke-500 mb-6">
        Start typing to search, or use a prefix to narrow results
      </p>

      <div class="flex flex-wrap gap-2 justify-center">
        <% prefixes.each do |p| %>
          <%= render "dashboard/prefix_button", prefix: p[:prefix], label: p[:label], variant: :chip %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
