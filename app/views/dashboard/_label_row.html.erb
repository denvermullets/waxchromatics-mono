<%
  label = result
  release_count = @variant_counts[label.id] || 0
%>
<div class="flex items-center gap-4 p-4 rounded-sm border border-woodsmoke-700 bg-woodsmoke-925 hover:border-prelude-400 hover:border-l-2 hover:border-l-prelude-400 transition-colors group">
  <div class="shrink-0 w-10 h-10 rounded bg-prelude-950 flex items-center justify-center">
    <svg class="w-5 h-5 text-prelude-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
      <rect x="3" y="3" width="18" height="18" rx="2" />
      <path d="M3 9h18M9 21V9" />
    </svg>
  </div>

  <div class="flex-1 min-w-0">
    <p class="font-semibold text-woodsmoke-50 truncate"><%= label.name %></p>
    <% if label.parent_label.present? %>
      <p class="text-sm text-woodsmoke-400">Sublabel of <span class="text-woodsmoke-300"><%= label.parent_label.name %></span></p>
    <% end %>
  </div>

  <div class="shrink-0 flex items-center gap-2">
    <% if release_count > 0 %>
      <span class="px-2 py-0.5 text-xs rounded-sm bg-woodsmoke-800 text-woodsmoke-300 font-medium">
        <%= release_count %> <%= "release".pluralize(release_count) %>
      </span>
    <% end %>
    <svg class="w-4 h-4 text-woodsmoke-600 group-hover:text-woodsmoke-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </div>
</div>
