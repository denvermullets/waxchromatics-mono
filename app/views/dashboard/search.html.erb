<%= turbo_frame_tag "search-results" do %>
  <%# Turbo Stream subscription for real-time updates from background jobs %>
  <%= turbo_stream_from "search_updates" %>

  <% if @query.present? %>
    <%
      partial_map = {
        'artist'  => 'dashboard/artist_row_search',
        'album'   => 'dashboard/album_row',
        'label'   => 'dashboard/label_row',
        'cat#'    => 'dashboard/catalog_row',
        'barcode' => 'dashboard/barcode_row',
        'credit'  => 'dashboard/credit_row',
      }
      row_partial = partial_map[@search_type]
    %>

    <div class="mt-8">
      <%# Results header: "RESULTS (N)" + type badge + separator line %>
      <div class="flex items-center justify-between mb-1">
        <p class="text-xs font-semibold uppercase tracking-wider text-woodsmoke-400">
          Results (<%= @total_count %>)
        </p>
        <%= render "dashboard/search_type_badge", type: @search_type %>
      </div>
      <hr class="border-woodsmoke-800 mb-4">

      <% if @results.any? %>
        <div class="flex flex-col gap-2">
          <% @results.each do |result| %>
            <%= render row_partial, result: result %>
          <% end %>
        </div>
      <% else %>
        <div class="py-12 text-center">
          <svg class="w-10 h-10 mx-auto text-woodsmoke-700 mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <p class="text-woodsmoke-400">No results found for "<%= @term %>"</p>
          <p class="text-xs text-woodsmoke-500 mt-1">Try a different search term</p>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>
